# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
# font-family = Iosevka
# window-padding-x = 2
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms
# theme = Everforest Light Med
# theme = Wombat
theme = warm-burnout-dark

font-family = Triplicate A Code
font-size = 18
copy-on-select = clipboard

keybind = performable:ctrl+c=copy_to_clipboard
keybind = performable:ctrl+v=paste_from_clipboard
keybind = ctrl+shift+j=scroll_page_lines:1
keybind = ctrl+shift+k=scroll_page_lines:-1
keybind = shift+enter=text:\x1b\r
keybind = ctrl+x>o=goto_split:next
keybind = alt+x=toggle_command_palette

keybind = escape=activate_key_table:normal
keybind = normal/i=deactivate_key_table
keybind = normal/super+escape=deactivate_key_table
keybind = normal/escape=text:\x1b



keybind = normal/space=activate_key_table_once:commands
keybind = commands/super+escape=deactivate_key_table
keybind = commands/x>o=goto_split:next
keybind = commands/3=new_split:down
keybind = commands/3=new_split:right
keybind = commands/m>x=toggle_command_palette
keybind = commands/x>p=activate_key_table_once:panes

keybind = panes/super+escape=deactivate_key_table
keybind = panes/z=toggle_split_zoom
keybind = panes/s=activate_key_table_once:panes_split

keybind = panes_split/super+escape=deactivate_key_table
keybind = panes_split/h=new_split:right
keybind = panes_split/v=new_split:down

# Editor mode: passthrough for emacs — super+escape to toggle
keybind = super+escape=activate_key_table:editor
keybind = editor/super+escape=deactivate_key_table
keybind = editor/ctrl+x>o=text:\x18o
keybind = editor/ctrl+shift+j=ignore
keybind = editor/ctrl+shift+k=ignore
keybind = editor/escape=text:\x1b

notify-on-command-finish = unfocused
notify-on-command-finish-action = bell,notify
notify-on-command-finish-after = 5s

gtk-tabs-location = top
unfocused-split-opacity = 0.2
