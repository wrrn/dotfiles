Include config.d/*

Host *
    IgnoreUnknown UseKeychain
    UseKeychain yes
    ## Prevent the identity file from always being added
    # AddKeysToAgent yes
    # IdentityFile ~/.ssh/id_ed25519

Host github.com
    AddKeysToAgent yes
    IdentityFile ~/.ssh/id_ed25519

Host git.sr.ht
    AddKeysToAgent yes
    IdentityFile ~/.ssh/id_ed25519

Host wrrn.sr.ht
    IgnoreUnknown UseKeychain
    Hostname git.sr.ht
    UseKeychain yes
    AddKeysToAgent yes
    IdentityFile ~/.ssh/wrrn.srht
    IdentitiesOnly yes

